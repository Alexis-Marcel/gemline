# Copy to .env (or .env.local) and fill in. Both are loaded at startup;
# .env.local takes precedence over .env when both exist.

# Postgres connection string. Use Supabase's "Connection pooling → Session"
# string in production. For offline dev via docker-compose:
#   postgres://gemline:gemline@localhost:5432/gemline?sslmode=disable
DATABASE_URL=

# Supabase project URL (Settings → API → Project URL). When set, the
# backend fetches the public signing keys from
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json and verifies user JWTs
# asymmetrically. Required for projects on Supabase's 2025 default
# (JWT Signing Keys, ES256/RS256).
SUPABASE_URL=

# Listen address. Defaults to :8080 when unset.
# ADDR=:8080
