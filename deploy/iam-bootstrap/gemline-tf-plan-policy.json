{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOIDCBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketPolicy",
        "s3:GetBucketPublicAccessBlock",
        "s3:GetBucketTagging",
        "s3:GetBucketLocation",
        "s3:GetBucketAcl",
        "s3:ListBucket",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::gemline-cluster-oidc-386324384913",
        "arn:aws:s3:::gemline-cluster-oidc-386324384913/*"
      ]
    },
    {
      "Sid": "ReadIAM",
      "Effect": "Allow",
      "Action": [
        "iam:GetOpenIDConnectProvider",
        "iam:ListOpenIDConnectProviders",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies"
      ],
      "Resource": [
        "arn:aws:iam::386324384913:oidc-provider/*",
        "arn:aws:iam::386324384913:role/gemline-*"
      ]
    },
    {
      "Sid": "ReadSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetResourcePolicy",
        "secretsmanager:ListSecretVersionIds"
      ],
      "Resource": "arn:aws:secretsmanager:eu-west-3:386324384913:secret:gemline/*"
    },
    {
      "Sid": "ReadTfVars",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:eu-west-3:386324384913:secret:gemline/tf-vars-*"
    },
    {
      "Sid": "ListSecretsAccountWide",
      "Effect": "Allow",
      "Action": "secretsmanager:ListSecrets",
      "Resource": "*"
    },
    {
      "Sid": "ReadLokiChunksBucket",
      "Effect": "Allow",
      "Action": [
        "s3:Get*",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::gemline-loki-chunks-386324384913"
    }
  ]
}
