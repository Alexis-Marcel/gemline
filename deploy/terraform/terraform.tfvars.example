# Copy to terraform.tfvars (gitignored) and fill in.

# Hetzner Cloud API token (Console → Security → API Tokens, Read & Write).
hcloud_token = ""

# Shared join secret for every k3s node in this cluster.
# Generate once with: openssl rand -hex 32
# (Anyone with this token can register as a node, so treat it like a password.)
k3s_token = ""

# Cloudflare API token with "Edit zone DNS" on var.dns_zone. Used to
# create/update the A record pointing var.dns_subdomain.var.dns_zone at
# the control-plane public IP. Create at
# Cloudflare → My Profile → API Tokens → Create Token (Edit zone DNS).
cloudflare_api_token = ""

# Domain pieces — defaults produce "gemline.werilo.fr". The zone must
# already be served by Cloudflare's nameservers.
# dns_zone      = "werilo.fr"
# dns_subdomain = "gemline"

# Number of worker nodes. 0 = single-node cluster (CP only).
# 1 = a 2-node cluster (CP + 1 worker). Default if unset.
# worker_count = 1

# Optional overrides
# server_type         = "cx23"          # cx23 = 2 vCPU / 4 GB, sweet spot for k3s
# worker_server_type  = "cx23"
# location            = "fsn1"          # fsn1 / nbg1 / hel1 / ash / hil
# network_zone        = "eu-central"    # eu-central / us-east / us-west
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Source IPs allowed to talk to the Kubernetes API (:6443). Empty = closed,
# kubectl works only via SSH tunnel. To enable direct kubectl from your
# laptop, list your public IPv4 (/32) and ideally your IPv6 /64 prefix:
#   curl -s -4 ifconfig.me           # IPv4
#   curl -s -6 ifconfig.me           # full IPv6, take the first 4 groups + "::/64"
# kubeapi_allowed_ips = [
#   "82.65.x.y/32",
#   "2a01:cb0c:18f7:5d00::/64",
# ]
